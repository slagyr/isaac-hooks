{:id       :isaac.hooks
 :version  "0.1.2"
 :builtin? true
 :factory  isaac.module.protocol/module

 :berths
 {:isaac.hooks/hook {:description "Event hooks installed into the hook registry. Per-entry factory resolves :factory and registers the returned spec via isaac.hooks/register-hook!."
                     :schema      {:type       :map
                                   :key-spec   {:type :keyword}
                                   :value-spec {:type    :map
                                                :factory isaac.hooks/register-hook-entry!
                                                :schema  {:factory {:type :symbol :validations [:present?]}}}}}}

 ;; Route contribution to the server's :isaac.server/route berth (data only —
 ;; inert when no HTTP host is loaded; no code dependency on isaac-server).
 :isaac.server/route
 [{:method :* :path "/hooks/*" :handler isaac.hooks/handler}]

 :isaac.config/schema
 {:hooks {:entity-dir   "hooks"
          :frontmatter? true
          :companion    {:field :template :mode :required}
          :schema       {:name        :hooks
                         :type        :map
                         :description "Webhook configuration"
                         :key-spec    {:type :string}
                         :value-spec  {:name        :hook
                                       :type        :map
                                       :description "Webhook receiver configuration"
                                       :schema      {:crew             {:type        :id
                                                                        :description "Select sessions whose :crew matches"
                                                                        :validations [:crew-exists?]}
                                                     :create           {:type        :keyword
                                                                        :description "Create policy: :never, :if-missing, or :always"
                                                                        :validations [[:one-of? :never :if-missing :always]]}
                                                     :id               {:type        :id
                                                                        :description "Hook id; must match filename when present"}
                                                     :model            {:type        :id
                                                                        :description "Legacy model override; prefer :with-model"
                                                                        :validations [:model-exists?]}
                                                     :prefer           {:type        :keyword
                                                                        :description "Multi-match tiebreak when multiple sessions match"
                                                                        :validations [[:one-of? :recent :oldest]]}
                                                     :reach            {:type        :keyword
                                                                        :description "How many sessions to target"
                                                                        :validations [[:one-of? :one :all]]}
                                                     :session          {:type        :seq
                                                                        :description "Explicit session id(s)"
                                                                        :spec        {:type :string}}
                                                     :session-key      {:type        :string
                                                                        :description "Legacy explicit session id; prefer :session"}
                                                     :session-tags     {:type        :seq
                                                                        :description "Tags sessions must carry (AND)"
                                                                        :spec        {:type :keyword}}
                                                     :template         {:type        :string
                                                                        :description "Rendered message template for the hook body"}
                                                     :with-context-mode {:type        :keyword
                                                                         :description "Override context mode for this turn"}
                                                     :with-crew        {:type        :id
                                                                        :description "Override crew for this turn"
                                                                        :validations [:crew-exists?]}
                                                     :with-effort      {:type        :int
                                                                        :description "Override effort for this turn"}
                                                     :with-model       {:type        :id
                                                                        :description "Override model for this turn"
                                                                        :validations [:model-exists?]}}}
                         :schema      {:auth {:name        :hook-auth
                                              :type        :map
                                              :description "Retired webhook auth configuration"
                                              :schema      {:token {:type        :string
                                                                    :validations [[:retired? "use :server :auth :token"]]}}}}}}}}
